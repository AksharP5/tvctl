{
  "name": "tvctl",
  "version": "0.2.0",
  "description": "A terminal remote and CLI for Roku TVs.",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "tvctl": "bin/tvctl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AksharP5/tvctl.git"
  },
  "bugs": {
    "url": "https://github.com/AksharP5/tvctl/issues"
  },
  "homepage": "https://github.com/AksharP5/tvctl#readme",
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/tvctl",
    "start": "bun src/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "directories": {
    "bin": "bin"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.2.10",
    "cac": "^7.0.0",
    "fast-xml-parser": "^5.8.0"
  }
}
